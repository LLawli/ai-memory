# Template for docker/.env. Copy to docker/.env (gitignored) and fill in
# values. Loaded automatically by `docker compose` when run from this
# directory.

# -------------------------------------------------------------------
# Required when the `claude-shim` profile is active:
#   docker compose --profile claude-shim up -d
# -------------------------------------------------------------------

# OAuth token from `claude setup-token` on a machine with Claude Code
# installed and logged in. Long-lived credential tied to your Claude
# Max/Pro subscription — treat like a password.
CLAUDE_CODE_OAUTH_TOKEN=

# These three together activate the LLM-backed paths in ai-memory
# (memory_consolidate, lint LLM pass, bootstrap) and point them at the
# shim. Without them, ai-memory boots in FTS5-only / rule-based mode.
AI_MEMORY_LLM_PROVIDER=anthropic
AI_MEMORY_LLM_MODEL=claude-opus-4-7
AI_MEMORY_LLM_BASE_URL=http://claude-shim:8080

# -------------------------------------------------------------------
# Optional
# -------------------------------------------------------------------

# Real Anthropic key — only needed if you want to bypass the shim and
# hit api.anthropic.com directly. The placeholder in docker-compose.yml
# is enough to satisfy the construction-time check when using the shim.
# ANTHROPIC_API_KEY=sk-ant-api-...
